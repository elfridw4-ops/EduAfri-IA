{
  "entities": {
    "User": {
      "title": "User",
      "description": "Enseignant utilisant la plateforme",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "PedagogicalContent": {
      "title": "Pedagogical Content",
      "description": "Contenu généré par l'IA (plan de cours, quiz, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["lesson_plan", "exercises", "quiz", "simplification", "activity", "evaluation", "revision_sheet"] },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "level": { "type": "string" },
        "country": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profils des enseignants"
    },
    "/contents/{contentId}": {
      "schema": "PedagogicalContent",
      "description": "Contenus pédagogiques générés"
    }
  }
}
